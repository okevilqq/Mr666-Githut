# ============================================================
# 链商2.0 项目 .gitignore
# 版本控制范围：生成脚本（generate_*.js）+ 配置文件 + 项目说明
# 排除范围：依赖包 / 生成产物 / 内部工具 / 参考素材
# ============================================================

# ---- Node.js 依赖 ----
node_modules/

# ---- Claude Code 内部文件 ----
.claude/
.agents/

# ---- 生成产物：Excel ----
*.xlsx

# ---- 生成产物：Word ----
*.docx
# 例外：原始模板文件不排除（如有）
!template*.docx

# ---- 生成产物：PDF / 图片 ----
*.pdf
*.png
*.jpg
*.jpeg
*.gif
*.svg
*.ico

# ---- 生成产物：XMind / HTML 可视化 ----
*.xmind
# HTML 可视化产物在日期目录中，由日期目录规则统一排除

# ---- 临时文件 ----
_temp_*.txt
*.tmp
*.log

# ---- 日期输出目录（所有 2026xxxx 格式的生成物目录） ----
202[0-9][0-9][0-9][0-9][0-9]*/
202[0-9][0-9][0-9][0-9][0-9][0-9]*/

# ---- 其他按名称命名的输出/资料目录 ----
工作日志/
资料收集/

# ---- Claude 结构化输出缓存 ----
structured_output_*.json

# ---- 操作系统文件 ----
Thumbs.db
Desktop.ini
.DS_Store

# ---- IDE / 编辑器 ----
.vscode/
.idea/
*.swp
*.swo
*~

# ---- 压缩包 ----
*.zip
*.rar
*.7z
*.tar.gz
